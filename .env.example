# Local bridge
SELF_CANVAS_HOST=127.0.0.1
SELF_CANVAS_PORT=8787
OUTPUT_DIR=output

# Redis / BullMQ
REDIS_URL=redis://127.0.0.1:6379/0
GENERATION_QUEUE_NAME=selfcanvas-generation
GENERATION_WORKER_CONCURRENCY=1

# Sub2API OpenAI-compatible provider
SUB2API_BASE_URL=http://10.0.0.239:3000
SUB2API_API_KEY=
SUB2API_TEXT_MODEL=gpt-4o-mini
SUB2API_IMAGE_MODEL=gpt-image-2
SUB2API_IMAGE_SIZE=1024x1024

# AnyCap CLI media provider
ANYCAP_BIN=anycap
ANYCAP_VIDEO_MODEL=seedance-2-fast
ANYCAP_VIDEO_MODE=text-to-video
ANYCAP_AUDIO_MODEL=
